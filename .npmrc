# pnpm / npm settings for this repo.
# Enforce the Node/pnpm engine floors declared in package.json.
engine-strict=true

# --- Supply-chain hardening (Shai-Hulud-class mitigations) ---
# Do not run package install lifecycle scripts (preinstall/postinstall) — the
# primary entry point for compromised-package attacks. Run explicitly if ever needed.
ignore-scripts=true

# Block freshly-published third-party versions for a cooldown window. Our own
# first-party packages would be excluded here if we had any (we don't yet).
# npm reads this in DAYS; pnpm's equivalent (minimumReleaseAge) is in minutes.
min-release-age=7

# Git-URL dependencies bypass version-age cooldowns entirely — disallow them.
allow-git=none
